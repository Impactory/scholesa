default_platform(:ios)
opt_out_usage

require 'base64'
require 'spaceship'
require 'yaml'

def require_env_values!(keys)
  missing = keys.select { |key| ENV[key].to_s.strip.empty? }
  return if missing.empty?

  UI.user_error!("Missing required environment values: #{missing.join(', ')}")
end


def app_root
  File.expand_path('../..', __dir__)
end

def flutter_binary
  configured = ENV['FLUTTER_BIN'].to_s.strip
  return configured unless configured.empty?

  fvm_binary = File.join(app_root, '.fvm', 'flutter_sdk', 'bin', 'flutter')
  return fvm_binary if File.exist?(fvm_binary)

  'flutter'
end

def flutter_release_version
  pubspec_path = File.join(app_root, 'pubspec.yaml')
  version = YAML.load_file(pubspec_path).fetch('version').to_s.strip
  match = version.match(/\A(?<name>\d+\.\d+\.\d+)\+(?<number>\d+)\z/)
  UI.user_error!("Expected pubspec.yaml version to use semantic version plus build number, got: #{version}") unless match

  { name: match[:name], number: match[:number] }
end

def app_store_connect_api_key_options
  require_env_values!(%w[APP_STORE_CONNECT_KEY_ID APP_STORE_CONNECT_ISSUER_ID])

  key_id = ENV['APP_STORE_CONNECT_KEY_ID'].to_s.strip
  issuer_id = ENV['APP_STORE_CONNECT_ISSUER_ID'].to_s.strip

  options = {
    key_id: key_id,
    issuer_id: issuer_id,
    duration: 1200,
    in_house: false,
  }

  key_path = ENV['APP_STORE_CONNECT_API_KEY_PATH'].to_s.strip
  key_b64 = ENV['APP_STORE_CONNECT_API_KEY_P8_BASE64'].to_s.strip

  unless key_path.empty?
    UI.user_error!("App Store Connect key file not found: #{key_path}") unless File.exist?(key_path)
    options[:key_filepath] = key_path
    return options
  end

  unless key_b64.empty?
    options[:key_content] = Base64.strict_decode64(key_b64)
    return options
  end

  UI.user_error!('Set APP_STORE_CONNECT_API_KEY_PATH or APP_STORE_CONNECT_API_KEY_P8_BASE64 before running Fastlane.')
end

def scholesa_api_key
  app_store_connect_api_key(**app_store_connect_api_key_options)
end

def verify_app_store_connect_api_key!(api_key)
  options = app_store_connect_api_key_options
  token_options = {
    key_id: options[:key_id],
    issuer_id: options[:issuer_id],
    duration: options[:duration],
    in_house: options[:in_house],
  }
  token_options[:filepath] = options[:key_filepath] if options[:key_filepath]
  token_options[:key] = options[:key_content] if options[:key_content]

  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**token_options)
  Spaceship::ConnectAPI::App.all(limit: 1)
rescue Spaceship::UnauthorizedAccessError => error
  UI.user_error!("App Store Connect .p8 key loaded locally, but Apple rejected live API auth: #{error.message}. Verify the key id, issuer id, team, and access role in App Store Connect.")
end

def verify_expected_testflight_build!(bundle_id, release_version)
  app = Spaceship::ConnectAPI::App.find(bundle_id)
  UI.user_error!("App Store Connect app not found for bundle id #{bundle_id}.") unless app

  builds = app.get_builds(limit: 100, sort: '-uploadedDate')
  matching_build = builds.find { |build| build.version.to_s == release_version[:number].to_s }
  UI.user_error!("Expected TestFlight build #{release_version[:number]} for #{bundle_id} is not visible in App Store Connect yet.") unless matching_build

  processing_state = matching_build.respond_to?(:processing_state) ? matching_build.processing_state : 'UNKNOWN'
  UI.success("Verified TestFlight build #{release_version[:number]} for #{bundle_id}; processing_state=#{processing_state}")
end

def provisioning_profile_dir
  File.expand_path('~/Library/MobileDevice/Provisioning Profiles')
end

def signing_output_dir(platform)
  File.join(app_root, 'build', platform, 'fastlane', 'signing')
end

def normalize_developer_id_certificate_type!
  certificate_type = Spaceship::ConnectAPI::Certificate::CertificateType
  supported_type = certificate_type::DEVELOPER_ID_APPLICATION
  return if certificate_type::DEVELOPER_ID_APPLICATION_G2 == supported_type

  certificate_type.send(:remove_const, :DEVELOPER_ID_APPLICATION_G2)
  certificate_type.const_set(:DEVELOPER_ID_APPLICATION_G2, supported_type)
end

def developer_id_account_holder_message(error)
  return unless error.message.include?('Account Holder')

  UI.user_error!("Apple requires the Account Holder to create Developer ID Application certificates. Generate a CSR with ./scripts/setup_macos_developer_id_csr.sh generate_csr, have the Account Holder create the Developer ID Application certificate in Apple Developer, then import the downloaded .cer with ./scripts/setup_macos_developer_id_csr.sh import_cer /path/to/certificate.cer. Original Apple response: #{error.message}")
end

platform :ios do
  desc 'Validate local or CI App Store Connect API key configuration'
  lane :verify_api_key do
    api_key = scholesa_api_key
    verify_app_store_connect_api_key!(api_key)
    UI.success("Verified live App Store Connect API auth for key #{ENV['APP_STORE_CONNECT_KEY_ID'].to_s.strip} and issuer #{ENV['APP_STORE_CONNECT_ISSUER_ID'].to_s.strip}")
  end

  desc 'Prepare iOS App Store signing from App Store Connect API key'
  lane :prepare_ios_signing do
    require_env_values!(%w[APPLE_DEVELOPER_TEAM_ID IOS_APP_IDENTIFIER])
    api_key = scholesa_api_key
    FileUtils.mkdir_p(provisioning_profile_dir)
    FileUtils.mkdir_p(signing_output_dir('ios'))

    cert(
      api_key: api_key,
      development: false,
      generate_apple_certs: true,
      platform: 'ios',
      team_id: ENV['APPLE_DEVELOPER_TEAM_ID'],
      output_path: signing_output_dir('ios')
    )

    sigh(
      api_key: api_key,
      app_identifier: ENV['IOS_APP_IDENTIFIER'],
      platform: 'ios',
      team_id: ENV['APPLE_DEVELOPER_TEAM_ID'],
      output_path: provisioning_profile_dir,
      filename: "Scholesa_AppStore_#{ENV['IOS_APP_IDENTIFIER']}.mobileprovision",
      readonly: false
    )
  end

  desc 'Prepare macOS Developer ID signing from App Store Connect API key'
  lane :prepare_macos_developer_id do
    require_env_values!(%w[APPLE_DEVELOPER_TEAM_ID])
    api_key = scholesa_api_key
    normalize_developer_id_certificate_type!
    FileUtils.mkdir_p(signing_output_dir('macos'))

    cert(
      api_key: api_key,
      type: 'developer_id_application',
      platform: 'macos',
      team_id: ENV['APPLE_DEVELOPER_TEAM_ID'],
      output_path: signing_output_dir('macos')
    )
  rescue Spaceship::UnexpectedResponse => error
    developer_id_account_holder_message(error)
    raise
  end

  desc 'Build a signed iOS release IPA and upload it to TestFlight'
  lane :upload_testflight do
    require_env_values!(%w[APPLE_DEVELOPER_TEAM_ID])
    api_key = scholesa_api_key
    release_version = flutter_release_version
    output_directory = File.join(app_root, 'build', 'ios', 'fastlane')
    ipa_path = File.join(output_directory, 'Scholesa.ipa')

    Dir.chdir(app_root) do
      sh("#{flutter_binary} pub get")
    end

    build_ios_app(
      workspace: 'Runner.xcworkspace',
      scheme: 'Runner',
      configuration: 'Release',
      clean: true,
      export_method: 'app-store',
      export_options: {
        provisioningProfiles: {
          ENV['IOS_APP_IDENTIFIER'].to_s.strip.empty? ? 'com.scholesa.app' : ENV['IOS_APP_IDENTIFIER'] => 'com.scholesa.app AppStore',
        },
      },
      output_directory: output_directory,
      output_name: 'Scholesa.ipa',
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_DEVELOPER_TEAM_ID']} FLUTTER_BUILD_NAME=#{release_version[:name]} FLUTTER_BUILD_NUMBER=#{release_version[:number]}"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end

  desc 'Verify the expected Flutter build number is visible in TestFlight'
  lane :verify_testflight_build do
    api_key = scholesa_api_key
    verify_app_store_connect_api_key!(api_key)
    release_version = flutter_release_version
    bundle_id = ENV['IOS_APP_IDENTIFIER'].to_s.strip.empty? ? 'com.scholesa.app' : ENV['IOS_APP_IDENTIFIER']
    verify_expected_testflight_build!(bundle_id, release_version)
  end
end