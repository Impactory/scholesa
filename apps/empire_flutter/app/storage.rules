rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile photos ──
    // Users can read any profile photo; only owner can write their own.
    match /users/{userId}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Portfolio artifacts ──
    // Owner writes; owner, parents, educators, staff can read.
    match /users/{userId}/portfolio/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // ── Site-scoped uploads (e.g. mission assets, curriculum docs) ──
    // Any authenticated user can read; only educators/staff write (enforced client-side + Cloud Functions).
    match /sites/{siteId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // ── Research consent documents ──
    match /research/{siteId}/consents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('application/pdf');
    }

    // ── Deny everything else ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
