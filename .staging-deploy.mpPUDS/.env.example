# Client-side Firebase config (public keys ok to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe publishable key (public - ok to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Optional: service worker settings
NEXT_PUBLIC_ENABLE_SW=false
NEXT_PUBLIC_SW_PATH=/sw.js

# Server-side (do NOT commit real secrets)
# Either set FIREBASE_SERVICE_ACCOUNT to the raw JSON or to base64(serviceAccountJson)
# Example (not real): FIREBASE_SERVICE_ACCOUNT={...}
FIREBASE_SERVICE_ACCOUNT=

# Alternative: use individual fields (Vercel-friendly)
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Internal AI provider controls (required)
SCHOLESA_AI_PROVIDER=INTERNAL_AI
SCHOLESA_TTS_PROVIDER=INTERNAL_TTS
SCHOLESA_STT_PROVIDER=INTERNAL_STT

# Google Cloud project / credentials (optional for ADC)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Stripe secrets (set via Firebase Secrets Manager, NOT here)
# Use: firebase functions:secrets:set STRIPE_SECRET_KEY
# Use: firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
