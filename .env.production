# Example: projects/your-gcp-project/secrets/FIREBASE_SERVICE_ACCOUNT/versions/latest
FIREBASE_SERVICE_ACCOUNT_SECRET_NAME=projects/your-gcp-project/secrets/your-secret/versions/latest

# GCP deploy credentials (used by CI to push/deploy). Base64-encoded service account JSON
GCP_SA_KEY=BASE64_ENCODED_GCP_SERVICE_ACCOUNT_JSON
GCP_PROJECT_ID=your-gcp-project-id
GCP_CLOUD_RUN_SERVICE=your-cloud-run-service-name

# Optional toggles
ENABLE_SW=true
