# Production environment variables for Cloud Run / production
# Replace the placeholder values with your real production values before deploying.
NODE_ENV=production

# Public (client) Firebase config — required for client SDK in the browser
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyC4csH-LBRiikaAMyD5EQewcINLVrmXQbs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=studio-3328096157-e3f79.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=studio-3328096157-e3f79
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=studio-3328096157-e3f79.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=97120825720
NEXT_PUBLIC_FIREBASE_APP_ID=1:97120825720:web:71fa701dd5d4561f8bd88d

# Service worker path (if using PWA). Keep leading slash if file is in `public/`.
NEXT_PUBLIC_SW_PATH=/sw.js

# AI Model API Keys
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSyBDNv018qRu17tGVqDLsI-oMsEWIo08r9M

# Server-side Firebase Admin credentials
