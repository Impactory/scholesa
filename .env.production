# Option A (recommended): Base64-encoded service account JSON
FIREBASE_SERVICE_ACCOUNT=BASE64_ENCODED_SERVICE_ACCOUNT_JSON

# Stripe (only publishable key needed client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51Qs8pb2KtDjGnzdpAKeglT8TQt7dbyITLG4p9zMSlVwhCUZhTxBCS3LJsN7wiv2Y2k0M4B6VmHV9U6fQ3YYp78n100eHyREOCT

