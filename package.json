{
  "name": "scholesa",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "icons:sync": "bash ./apps/empire_flutter/app/scripts/sync_platform_icons.sh",
    "predev": "npm run icons:sync",
    "prebuild": "npm run icons:sync",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --runInBand",
    "test:integration:rules": "npx --yes firebase-tools emulators:exec --only firestore \"npx jest --runInBand --config jest.rules.config.js\"",
    "test:integration:analytics": "jest --runInBand --config jest.analytics.config.js",
    "test:integration:analytics:live": "npx --yes firebase-tools emulators:exec --only firestore \"RUN_EXTERNAL_ANALYTICS_TESTS=1 jest --runInBand --config jest.analytics.config.js\"",
    "qa:telemetry-smoke": "node scripts/telemetry_smoke_check.js --mode=full --strict",
    "qa:telemetry-live-audit": "node scripts/telemetry_live_regression_audit.js --strict",
    "qa:telemetry-live-audit:coverage": "node scripts/telemetry_live_regression_audit.js --strict",
    "qa:telemetry-live-repair": "node scripts/telemetry_live_repair.js --strict",
    "qa:telemetry-live-repair:apply": "node scripts/telemetry_live_repair.js --apply --strict",
    "qa:telemetry-live-seed": "node scripts/telemetry_live_seed_coverage.js --strict",
    "qa:telemetry-live-seed:apply": "node scripts/telemetry_live_seed_coverage.js --apply --strict",
    "qa:vibe-telemetry:audit": "node scripts/vibe_telemetry_audit_master.js --strict",
    "qa:vibe-telemetry:blockers": "node scripts/vibe_ci_blocker_gate.js --strict",
    "qa:tts-stt-bos:no-gap": "node scripts/tts_stt_bos_no_gap_assurance.js --strict",
    "qa:firebase-ui-field-wiring": "node scripts/audit_firebase_ui_field_wiring.js --strict",
    "qa:firebase-ui-field-wiring:bulk": "node scripts/audit_firebase_ui_field_wiring_bulk.js --strict",
    "docs:telemetry:wiring:sync": "node scripts/docs_telemetry_wiring_sync.js",
    "vibe:i18n:lint": "node scripts/vibe_i18n_lint.js",
    "vibe:i18n:keys": "node scripts/vibe_i18n_keys.js",
    "vibe:ui:screens:i18n": "node scripts/vibe_ui_screens_i18n.js",
    "vibe:api:locale": "node scripts/vibe_api_locale.js",
    "vibe:ai:guardrails:i18n": "node scripts/vibe_ai_guardrails_i18n.js",
    "vibe:ai:language": "node scripts/vibe_ai_language.js",
    "vibe:data:utf8": "node scripts/vibe_data_utf8.js",
    "vibe:voice:fixtures": "node scripts/vibe_voice_fixtures.js",
    "vibe:voice:tenant-isolation": "node scripts/vibe_voice_tenant_isolation.js",
    "vibe:voice:role-policy": "node scripts/vibe_voice_role_policy.js",
    "vibe:voice:egress-none": "node scripts/vibe_voice_egress.js",
    "vibe:voice:stt-smoke": "node scripts/vibe_stt_smoke.js",
    "vibe:voice:trace-continuity": "node scripts/vibe_voice_trace_continuity.js",
    "vibe:voice:tts-pronunciation": "node scripts/vibe_tts_pronunciation.js",
    "vibe:voice:tts-prosody-policy": "node scripts/vibe_tts_prosody_policy.js",
    "vibe:voice:utf8": "node scripts/vibe_voice_utf8.js",
    "vibe:voice:quiet-mode": "node scripts/vibe_voice_quiet_mode.js",
    "vibe:voice:abuse-safety": "node scripts/vibe_voice_abuse_safety.js",
    "vibe:voice:all": "node scripts/vibe_voice_all.js",
    "vibe:voice:all:live": "node scripts/vibe_voice_live_runner.js --strict",
    "vibe:compliance:notice:i18n": "node scripts/vibe_compliance_notice_i18n.js",
    "ai:dependency-ban": "node scripts/ai_dependency_ban.js",
    "ai:import-ban": "node scripts/ai_import_ban.js",
    "ai:domain-ban": "node scripts/ai_domain_ban.js",
    "ai:egress-none": "node scripts/ai_egress_none.js",
    "ai:internal-only:all": "npm run ai:dependency-ban && npm run ai:import-ban && npm run ai:domain-ban && npm run ai:egress-none",
    "compliance:scan": "node services/scholesa-compliance/src/cli.js --scan-only",
    "compliance:run": "node services/scholesa-compliance/src/cli.js --trigger=manual-cli",
    "compliance:gate": "node services/scholesa-compliance/src/cli.js --trigger=ci",
    "compliance:serve": "node services/scholesa-compliance/src/server.js",
    "vibe:all": "node scripts/vibe_all.js",
    "rc2:regression": "bash ./scripts/rc2_regression.sh",
    "audit:coppa:no-ads": "bash ./scripts/coppa_no_ad_audit.sh",
    "test:cta-report": "python3 -m unittest scripts/test_cta_report_policy.py",
    "test:cta-report:generate": "npm run test:cta-report && python3 scripts/generate_cta_report.py",
    "test:cta-report:gate": "npm run test:cta-report:generate && python3 scripts/check_cta_report_gate.py"
  },
  "dependencies": {
    "@dataconnect/admin-generated": "file:src/dataconnect-admin-generated",
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@headlessui/react": "^2.1.2",
    "@heroicons/react": "^2.1.5",
    "@stripe/stripe-js": "^8.6.1",
    "@types/express": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "ajv": "^8.18.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.6.0",
    "framer-motion": "^11.3.8",
    "lucide-react": "^0.560.0",
    "next": "^14.2.35",
    "next-pwa": "^5.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-firebase-hooks": "^5.1.1",
    "tailwind-merge": "^2.3.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@jest/globals": "^29.7.0",
    "@next/eslint-plugin-next": "^16.1.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.2",
    "eslint-config-google": "^0.14.0",
    "eslint-config-next": "^16.1.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "ts-jest": "^29.4.5",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.53.0"
  }
}
