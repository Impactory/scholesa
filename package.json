{
  "name": "scholesa",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --runInBand --passWithNoTests",
    "test:integration:rules": "firebase emulators:exec --only firestore \"npx jest --runInBand --config jest.rules.config.js\"",
    "test:integration:analytics": "node -e \"if(process.env.RUN_EXTERNAL_ANALYTICS_TESTS==='1'){process.exit(0)};console.log('Skipping external analytics integration tests (set RUN_EXTERNAL_ANALYTICS_TESTS=1 to enable).');\" && ( [ \"$RUN_EXTERNAL_ANALYTICS_TESTS\" = \"1\" ] && jest --runInBand --config jest.analytics.config.js || true )",
    "test:integration:analytics:live": "firebase emulators:exec --only firestore \"RUN_EXTERNAL_ANALYTICS_TESTS=1 jest --runInBand --config jest.analytics.config.js\"",
    "test:cta-report": "python3 -m unittest scripts/test_cta_report_policy.py",
    "test:cta-report:generate": "npm run test:cta-report && python3 scripts/generate_cta_report.py",
    "test:cta-report:gate": "npm run test:cta-report:generate && python3 scripts/check_cta_report_gate.py"
  },
  "dependencies": {
    "@dataconnect/admin-generated": "file:src/dataconnect-admin-generated",
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@headlessui/react": "^2.1.2",
    "@heroicons/react": "^2.1.5",
    "@stripe/stripe-js": "^8.6.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.6.0",
    "framer-motion": "^11.3.8",
    "lucide-react": "^0.560.0",
    "next": "^16.1.6",
    "next-pwa": "^0.0.1",
    "react": "^18",
    "react-dom": "^18",
    "react-firebase-hooks": "^5.1.1",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^0.1.0",
    "@eslint/js": "^9.39.2",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@jest/globals": "^27.5.1",
    "@next/eslint-plugin-next": "^16.1.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^6.15.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.0.1",
    "eslint-config-google": "^0.14.0",
    "eslint-config-next": "^0.2.4",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "jest": "^19.0.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "ts-jest": "^27.0.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.36.0"
  }
}
