rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Fetch user profile to check role (costs 1 read)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isEducator() {
      return hasRole('educator') || hasRole('siteLead') || hasRole('hq');
    }
    
    function isHQ() {
      return hasRole('hq');
    }

    // --- Collection Rules ---

    // Users: 
    // - Users can read/write their own profile.
    // - Educators/HQ can read profiles (to view learners).
    match /users/{userId} {
      allow read: if isOwner(userId) || isEducator();
      allow create: if isOwner(userId); // Needed for AuthProvider.signUp
      allow update: if isOwner(userId) || isHQ();
    }

    // Content (Sites, Rooms, Programs, Courses, Missions):
    // - Read: All authenticated users.
    // - Write: HQ or Site Leads (depending on scope, defaulting to HQ/Educator for simplicity).
    match /sites/{id} { allow read: if isAuthenticated(); allow write: if isHQ(); }
    match /rooms/{id} { allow read: if isAuthenticated(); allow write: if isEducator(); }
    match /programs/{id} { allow read: if isAuthenticated(); allow write: if isHQ(); }
    match /courses/{id} { allow read: if isAuthenticated(); allow write: if isHQ(); }
    match /missions/{id} { allow read: if isAuthenticated(); allow write: if isHQ(); }

    // Operational (Sessions, Occurrences):
    // - Read: All authenticated users (could be scoped to site).
    // - Write: Educators.
    match /sessions/{id} { allow read: if isAuthenticated(); allow write: if isEducator(); }
    match /sessionOccurrences/{id} { allow read: if isAuthenticated(); allow write: if isEducator(); }

    // Student Data (Enrolments, Attendance):
    // - Read: Owner or Educator.
    // - Write: Educator.
    match /enrolments/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isEducator());
      allow write: if isEducator();
    }
    match /attendance/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isEducator());
      allow write: if isEducator();
    }

    // Learning Artifacts (MissionAttempts, Reflections):
    // - Read: Owner or Educator.
    // - Create: Owner (Learner).
    // - Update: Owner or Educator (for grading/feedback).
    match /missionAttempts/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
    }
    
    match /reflections/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Accountability & Portfolios
    match /accountabilityCycles/{id} { allow read: if isAuthenticated(); allow write: if isEducator(); }
    match /accountabilityKPIs/{id} { allow read: if isAuthenticated(); allow write: if isEducator(); }
    match /portfolioItems/{id} {
      allow read: if isAuthenticated(); // Portfolios might be public within school?
      allow write: if isOwner(resource.data.learnerId) || isEducator();
    }

    // --- Stripe & Billing Collections (Server-only writes) ---
    
    // Stripe Customers: Users can read their own, no client writes
    match /stripeCustomers/{userId} {
      allow read: if isOwner(userId) || isHQ();
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Checkout Intents: Users can read their own, no client writes
    match /checkoutIntents/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.actorId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Subscriptions: Users can read their own, no client writes
    match /subscriptions/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Entitlements: Users can read their own, no client writes
    match /entitlements/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Orders: Read for owner/HQ, no client writes
    match /orders/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }

    // Audit Logs: HQ read only, no client writes
    match /auditLogs/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only
    }

    // Telemetry: Users can write their own events, educators/HQ can read
    match /telemetryEvents/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isEducator() || isHQ();
      allow update, delete: if false; // Immutable once created
    }
    
    // Telemetry Aggregates: Read-only for educators/HQ, server writes only
    match /telemetryAggregates/{id} {
      allow read: if isEducator() || isHQ();
      allow write: if false; // Cloud Functions only
    }
    
    // SDT Motivation Collections
    
    // Learner Goals: Users can manage their own, educators can read
    match /learnerGoals/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update, delete: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
    }
    
    // Learner Interest Profiles: Users can manage their own, educators can read
    match /learnerInterestProfiles/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow delete: if false; // Keep historical data
    }
    
    // Skill Mastery: Educators can write, learners can read their own
    match /skillMastery/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isEducator();
      allow delete: if false; // Keep historical data
    }
    
    // Recognition Badges: Educators can award, learners can read their own
    match /recognitionBadges/{id} {
      allow read: if isAuthenticated() && (resource.data.recipientId == request.auth.uid || isEducator());
      allow create: if isEducator();
      allow update, delete: if false; // Immutable once awarded
    }
    
    // Learner Reflections: Users can write their own, educators can read
    match /learnerReflections/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.learnerId == request.auth.uid;
      allow delete: if false; // Keep growth timeline
    }
    
    // Checkpoint History: Educators can write, learners can read their own
    match /checkpointHistory/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isEducator();
      allow delete: if false; // Keep historical data
    }
    
    // Showcase Submissions: Public read, learners can submit their own
    match /showcaseSubmissions/{id} {
      allow read: if isAuthenticated(); // Public within school
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.learnerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.learnerId == request.auth.uid;
    }
    
    // Peer Feedback: Users can give feedback, educators can moderate
    match /peerFeedback/{id} {
      allow read: if isAuthenticated(); // Anyone can read peer feedback
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isEducator(); // Educators can moderate
    }
    
    // Vector Documents: Server-only (AI/embedding management)
    match /vectorDocuments/{id} {
      allow read: if isEducator() || isHQ(); // For debugging/admin
      allow write: if false; // Server-only via VectorStore/VectorIndexer
    }

    // Notification Requests: Educators can read their own requests
    match /notificationRequests/{id} {
      allow read: if isAuthenticated() && (resource.data.requestedBy == request.auth.uid || resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Stripe Webhook Logs: HQ read only, server writes
    match /stripeWebhookLogs/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via webhooks
    }
    
    // Stripe Disputes: HQ read only, server writes
    match /stripeDisputes/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via webhooks
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}