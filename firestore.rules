    // LTI collections — server-managed, educator/HQ read
    match /ltiPlatformRegistrations/{id} {
      allow read: if isAuthenticated() && (isEducator() || isHQ());
      allow write: if false; // Server-only
    }

    match /ltiResourceLinks/{id} {
      allow read: if isAuthenticated() && (isEducator() || isHQ());
      allow write: if false; // Server-only
    }

    match /ltiGradePassbackJobs/{id} {
      allow read: if isAuthenticated() && (isEducator() || isHQ());
      allow write: if false; // Server-only
    }

    // Learner support plans — educator creates/updates, site-scoped
    match /learnerSupportPlans/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isEducator();
      allow delete: if false;
    }

    // Learner differentiation plans — educator creates/updates, site-scoped
    match /learnerDifferentiationPlans/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isEducator();
      allow delete: if false;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
