    // Analytics events — learners write their own events, educators/HQ read
    match /analyticsEvents/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isEducator() || isHQ();
      allow update, delete: if false; // Immutable event log
    }

    // Learner badges — system/educator awards, learner reads own
    match /learnerBadges/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated();
      allow update, delete: if false; // Immutable once awarded
    }

