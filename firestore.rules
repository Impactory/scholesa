rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParentOf(learnerId) {
      return hasRole('parent') && (learnerId in getUserData().linkedLearnerIds);
    }
    
    // Users
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if hasRole('educator') || hasRole('hq') || hasRole('siteLead');
    }

    // Sites & Rooms
    match /sites/{siteId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hq') || hasRole('siteLead');
    }
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hq') || hasRole('siteLead');
    }

    // Programs, Courses, Missions
    match /programs/{programId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hq');
    }
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hq');
    }
    match /missions/{missionId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hq') || hasRole('educator');
    }

    // Sessions & SessionOccurrences
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hq') || hasRole('siteLead');
    }
    match /sessionOccurrences/{occurrenceId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hq') || hasRole('siteLead') || hasRole('educator');
    }

    // Enrolments
    match /enrolments/{enrolmentId} {
      allow read: if isOwner(resource.data.userId) || isParentOf(resource.data.userId) || hasRole('educator') || hasRole('hq') || hasRole('siteLead');
      allow write: if hasRole('educator') || hasRole('hq') || hasRole('siteLead');
    }

    // Attendance Records
    match /attendanceRecords/{attendanceId} {
      allow read: if isOwner(resource.data.userId) || isParentOf(resource.data.userId) || hasRole('educator') || hasRole('hq') || hasRole('siteLead');
      allow write: if hasRole('educator') || hasRole('hq') || hasRole('siteLead');
    }

    // Mission Plans
    match /missionPlans/{planId} {
      allow read, write: if hasRole('educator') || hasRole('hq') || hasRole('siteLead');
    }

    // Mission Attempts
    match /missionAttempts/{attemptId} {
      allow read: if isOwner(resource.data.learnerId) || isParentOf(resource.data.learnerId) || hasRole('educator') || hasRole('hq');
      allow create, update: if isOwner(request.resource.data.learnerId);
    }

    // Reflections
    match /reflections/{reflectionId} {
      allow read: if isOwner(resource.data.userId) || hasRole('educator') || hasRole('hq');
      allow create, update, delete: if isOwner(request.resource.data.userId);
    }

    // Accountability Cycles
    match /accountabilityCycles/{cycleId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('hq');
    }

    // Accountability KPIs
    match /accountabilityKPIs/{kpiId} {
      allow read: if isOwner(resource.data.learnerId) || isParentOf(resource.data.learnerId) || hasRole('educator') || hasRole('hq');
      allow write: if hasRole('hq');
    }

    // Accountability Commitments & Reviews
    match /accountabilityCommitments/{docId} {
       allow read: if isOwner(resource.data.learnerId) || hasRole('educator') || hasRole('hq');
       allow write: if isOwner(request.resource.data.learnerId);
    }
    match /accountabilityReviews/{docId} {
       allow read: if isOwner(resource.data.learnerId) || hasRole('educator') || hasRole('hq');
       allow write: if isOwner(request.resource.data.learnerId);
    }

    // Portfolios
    match /portfolioItems/{itemId} {
       allow read: if isOwner(resource.data.learnerId) || isParentOf(resource.data.learnerId) || hasRole('educator') || hasRole('hq') || hasRole('partner');
       allow write: if isOwner(request.resource.data.learnerId);
    }
    
    // Alerts (HQ/Educator/SiteLead)
    match /alerts/{alertId} {
      allow read, write: if hasRole('hq') || hasRole('educator') || hasRole('siteLead');
    }

    // Pillars (Read-only for all authenticated)
    match /pillars/{pillarId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }
  }
}
