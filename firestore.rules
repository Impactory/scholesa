    }

    // --- Partner & Contracting ---

    match /partnerOrgs/{id} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isHQ());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isHQ());
      allow delete: if false;
    }
    match /partnerContracts/{id} {
      allow read: if isAuthenticated() && (resource.data.partnerId == request.auth.uid || isHQ());
      allow create: if isHQ() || (isAuthenticated() && request.resource.data.partnerId == request.auth.uid);
      allow update: if isHQ() || (
        isAuthenticated()
        && resource.data.partnerId == request.auth.uid
        && request.resource.data.partnerId == resource.data.partnerId
      );
      allow delete: if false;
    }
    match /partnerDeliverables/{id} {
      allow read: if isAuthenticated() && (resource.data.partnerId == request.auth.uid || isHQ());
      allow create: if isAuthenticated()
        && request.resource.data.partnerId == request.auth.uid
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.contractId is string;
      allow update: if isHQ();
      allow delete: if false;
    }
    match /payouts/{id} {
      allow read: if isAuthenticated() && (resource.data.partnerId == request.auth.uid || isHQ());
