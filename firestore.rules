    match /mvlEpisodes/{id} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['evidenceEventIds']);
      allow delete: if false;
    }

    // fairnessAudits: server writes, HQ reads
    match /fairnessAudits/{id} {
      allow read: if isHQ() || isAdminOrHQ();
      allow create, update, delete: if false;
    }

    // classInsights: server writes, educator reads own site
    match /classInsights/{id} {
      allow read: if isAuthenticated() && (isEducator() || isHQ() || isAdminOrHQ());
      allow create, update, delete: if false;
    }

    match /syntheticDatasetImports/{id} {
      allow read: if isHQ() || isAdminOrHQ();
