    match /motivationAnalytics/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator() || isParentLinkedToLearner(resource.data.learnerId));
      allow create, update: if false; // Server-only via Cloud Functions
      allow delete: if false;
    }

