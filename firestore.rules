      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningCandidateModelPackages/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningCandidatePromotionRecords/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningCandidatePromotionRevocationRecords/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningPilotEvidenceRecords/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningPilotApprovalRecords/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningPilotExecutionRecords/{id} {
