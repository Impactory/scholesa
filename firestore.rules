rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Safe version that returns empty map if user has no profile
    function getUserDataSafe() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
    }
    
    function hasRoleSafe(role) {
      let userData = getUserDataSafe();
      return isAuthenticated() && userData.keys().hasAny(['role']) && userData.role == role;
    }
    
    function isEducator() {
      return hasRoleSafe('educator') || hasRoleSafe('siteLead') || hasRoleSafe('site') || hasRoleSafe('hq');
    }
    
    function isHQ() {
      return hasRoleSafe('hq');
    }

    function isAdminOrHQ() {
      return hasRoleSafe('admin') || isHQ();
    }

    function userHasSite(siteId) {
      return isAuthenticated() && (
        (getUserDataSafe().keys().hasAny(['siteId']) && getUserDataSafe().siteId == siteId) ||
        (getUserDataSafe().keys().hasAny(['siteIds']) && getUserDataSafe().siteIds.hasAny([siteId]))
      );
    }

    function hasSiteField(data) {
      return data.keys().hasAny(['siteId']);
    }

    function actorSiteIds() {
      return getUserDataSafe().keys().hasAny(['siteIds']) ? getUserDataSafe().siteIds : [];
    }

    function requestSharesActorSite(data) {
      return data.keys().hasAny(['siteIds']) && data.siteIds.hasAny(actorSiteIds());
    }

    function isParentLinkedToLearner(learnerId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(learnerId))
        && get(/databases/$(database)/documents/users/$(learnerId)).data.keys().hasAny(['parentIds'])
        && get(/databases/$(database)/documents/users/$(learnerId)).data.parentIds.hasAny([request.auth.uid]);
    }

    function isSiteScopedRead(data) {
      return hasSiteField(data) ? (isHQ() || userHasSite(data.siteId)) : true;
    }

    function isSiteScopedWrite(data) {
      return hasSiteField(data) ? (isHQ() || userHasSite(data.siteId)) : true;
    }

    // --- Collection Rules ---

    // Users: 
    // - Users can read/write their own profile.
    // - Educators/HQ can read profiles (to view learners).
    match /users/{userId} {
      allow read: if isOwner(userId) || isEducator();
      // Only HQ and site admins can create user profiles
      allow create: if isHQ() || (
        hasRoleSafe('site')
        && requestSharesActorSite(request.resource.data)
        && request.resource.data.keys().hasAny(['role'])
        && ['learner', 'parent'].hasAny([request.resource.data.role])
      );
      allow update: if isOwner(userId) || isHQ() || (
        hasRoleSafe('site')
        && requestSharesActorSite(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'siteIds',
          'activeSiteId',
          'parentIds',
          'displayName',
          'updatedAt'
        ])
      );
    }

    // Content (Sites, Rooms, Programs, Courses, Missions):
    // - Read: All authenticated users.
    // - Write: HQ or Site Leads (depending on scope, defaulting to HQ/Educator for simplicity).
    match /sites/{id} { allow read: if isAuthenticated() && isSiteScopedRead(resource.data); allow create, update: if isHQ() && isSiteScopedWrite(request.resource.data); allow delete: if false; }
    match /rooms/{id} { allow read: if isAuthenticated() && isSiteScopedRead(resource.data); allow write: if isEducator() && isSiteScopedWrite(request.resource.data); }
    match /programs/{id} { allow read: if isAuthenticated(); allow write: if isHQ(); }
    match /courses/{id} { allow read: if isAuthenticated(); allow write: if isHQ(); }
    match /missions/{id} { allow read: if isAuthenticated(); allow write: if isHQ(); }

    // Operational (Sessions, Occurrences):
    // - Read: All authenticated users (could be scoped to site).
    // - Write: Educators.
    match /sessions/{id} { allow read: if isAuthenticated() && isSiteScopedRead(resource.data); allow create, update: if isEducator() && isSiteScopedWrite(request.resource.data); allow delete: if false; }
    match /sessionOccurrences/{id} { allow read: if isAuthenticated() && isSiteScopedRead(resource.data); allow create, update: if isEducator() && isSiteScopedWrite(request.resource.data); allow delete: if false; }

    // Student Data (Enrollments, Attendance):
    // - Read: Owner or Educator.
    // - Write: Educator.
    match /enrollments/{id} {
      allow read: if isAuthenticated() && isSiteScopedRead(resource.data) && (
        resource.data.userId == request.auth.uid
        || resource.data.learnerId == request.auth.uid
        || isEducator()
        || (
          resource.data.keys().hasAny(['learnerId'])
          && isParentLinkedToLearner(resource.data.learnerId)
        )
      );
      allow create, update: if isEducator() && isSiteScopedWrite(request.resource.data);
      allow delete: if false;
    }
    match /attendanceRecords/{id} {
      allow read: if isAuthenticated() && isSiteScopedRead(resource.data) && (
        resource.data.userId == request.auth.uid
        || resource.data.learnerId == request.auth.uid
        || isEducator()
        || (
          resource.data.keys().hasAny(['learnerId'])
          && isParentLinkedToLearner(resource.data.learnerId)
        )
      );
      allow create, update: if isEducator() && isSiteScopedWrite(request.resource.data);
      allow delete: if false;
    }

    // Learning Artifacts (MissionAttempts, Reflections):
    // - Read: Owner or Educator.
    // - Create: Owner (Learner).
    // - Update: Owner or Educator (for grading/feedback).
    match /missionAttempts/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
    }
    
    match /reflections/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Accountability & Portfolios
    match /accountabilityCycles/{id} { allow read: if isAuthenticated(); allow create, update: if isEducator(); allow delete: if false; }
    match /accountabilityKPIs/{id} { allow read: if isAuthenticated(); allow create, update: if isEducator(); allow delete: if false; }
    match /portfolioItems/{id} {
      allow read: if isAuthenticated() && (
        resource.data.learnerId == request.auth.uid
        || isEducator()
        || isParentLinkedToLearner(resource.data.learnerId)
      );
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isOwner(resource.data.learnerId) || isEducator();
      allow delete: if isOwner(resource.data.learnerId) || isEducator();
    }

    // --- Stripe & Billing Collections (Server-only writes) ---
    
    // Stripe Customers: Users can read their own, no client writes
    match /stripeCustomers/{userId} {
      allow read: if isOwner(userId) || isHQ();
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Checkout Intents: Users can read their own, no client writes
    match /checkoutIntents/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.actorId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Subscriptions: Users can read their own, no client writes
    match /subscriptions/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Entitlements: Users can read their own, no client writes
    match /entitlements/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Orders: Read for owner/HQ, no client writes
    match /orders/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }

    // Audit Logs: HQ read only, no client writes
    match /auditLogs/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only
    }

    // Enterprise SSO provider catalog: readable for site/HQ operations, server-only writes.
    match /enterpriseSsoProviders/{id} {
      allow read: if isHQ() || hasRoleSafe('site');
      allow write: if false;
    }

    // Telemetry: Users can write their own events, educators/HQ can read
    match /telemetryEvents/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isEducator() || isHQ();
      allow update, delete: if false; // Immutable once created
    }
    
    // Telemetry Aggregates: Read-only for educators/HQ, server writes only
    match /telemetryAggregates/{id} {
      allow read: if isEducator() || isHQ();
      allow write: if false; // Cloud Functions only
    }
    
    // SDT Motivation Collections
    
    // Learner Goals: Users can manage their own, educators can read
    match /learnerGoals/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update, delete: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
    }
    
    // Learner Interest Profiles: Users can manage their own, educators can read
    match /learnerInterestProfiles/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow delete: if false; // Keep historical data
    }
    
    // Skill Mastery: Educators can write, learners can read their own
    match /skillMastery/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isEducator();
      allow delete: if false; // Keep historical data
    }
    
    // Recognition Badges: Educators can award, learners can read their own
    match /recognitionBadges/{id} {
      allow read: if isAuthenticated() && (resource.data.recipientId == request.auth.uid || isEducator());
      allow create: if isEducator();
      allow update, delete: if false; // Immutable once awarded
    }
    
    // Learner Reflections: Users can write their own, educators can read
    match /learnerReflections/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.learnerId == request.auth.uid;
      allow delete: if false; // Keep growth timeline
    }

    // Metacognitive Calibration Records: learners and educators can review longitudinal confidence vs. correctness history.
    match /metacognitiveCalibrationRecords/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && (request.resource.data.learnerId == request.auth.uid || isEducator());
      allow update: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow delete: if false; // Keep longitudinal calibration history
    }
    
    // Checkpoint History: Educators can write, learners can read their own
    match /checkpointHistory/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isEducator();
      allow delete: if false; // Keep historical data
    }
    
    // Showcase Submissions: Public read, learners can submit their own
    match /showcaseSubmissions/{id} {
      allow read: if isAuthenticated(); // Public within school
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.learnerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.learnerId == request.auth.uid;
    }
    
    // Peer Feedback: Users can give feedback, educators can moderate
    match /peerFeedback/{id} {
      allow read: if isAuthenticated(); // Anyone can read peer feedback
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isEducator(); // Educators can moderate
    }
    
    // Vector Documents: Server-only (AI/embedding management)
    match /vectorDocuments/{id} {
      allow read: if isEducator() || isHQ(); // For debugging/admin
      allow write: if false; // Server-only via VectorStore/VectorIndexer
    }

    // Notification Requests: Educators can read their own requests
    match /notificationRequests/{id} {
      allow read: if isAuthenticated() && (resource.data.requestedBy == request.auth.uid || resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only via Cloud Functions
    }
    
    // Stripe Webhook Logs: HQ read only, server writes
    match /stripeWebhookLogs/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via webhooks
    }
    
    // Stripe Disputes: HQ read only, server writes
    match /stripeDisputes/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via webhooks
    }
    
    // --- Missing Collections (Flutter app coverage) ---

    // Learner/Parent Profiles & GuardianLinks
    match /learnerProfiles/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow delete: if false;
    }
    match /parentProfiles/{id} {
      allow read: if isAuthenticated() && (resource.data.parentId == request.auth.uid || isEducator());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.parentId == request.auth.uid || isEducator() || isHQ());
      allow delete: if false;
    }
    match /guardianLinks/{id} {
      allow read: if isAuthenticated() && (resource.data.parentId == request.auth.uid || resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if (isEducator() || isHQ()) && isSiteScopedWrite(request.resource.data);
      allow delete: if false;
    }
    match /educatorLearnerLinks/{id} {
      allow read: if isAuthenticated() && (
        isHQ() ||
        (resource.data.keys().hasAny(['educatorId']) && resource.data.educatorId == request.auth.uid)
      );
      allow create, update: if isAuthenticated() && (
        isHQ() ||
        (request.resource.data.keys().hasAny(['educatorId']) && request.resource.data.educatorId == request.auth.uid)
      );
      allow delete: if false;
    }

    // Habits
    match /habits/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow delete: if false;
    }

    // Reference Data (Pillars, Skills)
    match /pillars/{id} { allow read: if isAuthenticated(); allow create, update: if isHQ(); allow delete: if false; }
    match /skills/{id} { allow read: if isAuthenticated(); allow create, update: if isHQ(); allow delete: if false; }

    // Mission Plans & Snapshots
    match /missionPlans/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isEducator();
      allow delete: if false;
    }
    match /missionSnapshots/{id} {
      allow read: if isAuthenticated();
      allow create: if isEducator();
      allow update, delete: if false;
    }
    match /proofOfLearningBundles/{id} {
      allow read: if isAuthenticated() && (
        resource.data.learnerId == request.auth.uid
        || isEducator()
        || (
          resource.data.keys().hasAny(['learnerId'])
          && isParentLinkedToLearner(resource.data.learnerId)
        )
      );
      allow create, update: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow delete: if false;
    }

    // Portfolios (container)
    match /portfolios/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.learnerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow delete: if false;
    }

    // Credentials
    match /credentials/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isEducator();
      allow delete: if false;
    }

    // Accountability sub-collections
    match /accountabilityCommitments/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isEducator();
      allow delete: if false;
    }
    match /accountabilityReviews/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isEducator() || isHQ();
      allow delete: if false;
    }

    // Announcements
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isEducator();
      allow delete: if isHQ();
    }

    // CMS Pages: Public read for published content, HQ writes
    match /cmsPages/{id} {
      allow read: if true; // Public pages readable without auth
      allow create, update: if isHQ();
      allow delete: if false;
    }

    // Leads: Unauthenticated create for lead capture, HQ reads
    match /leads/{id} {
      allow create: if true; // Public lead capture
      allow read: if isHQ();
      allow update: if isHQ();
      allow delete: if false;
    }

    // Messaging
    match /messageThreads/{id} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participantIds || isHQ());
      allow create: if isAuthenticated() && request.resource.data.participantIds.hasAny([request.auth.uid]);
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.participantIds
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'title',
                      'status',
                      'lastMessagePreview',
                      'lastMessageSenderId',
                      'participantNames',
                      'updatedAt'
                    ])
                    && request.resource.data.participantIds == resource.data.participantIds;
      allow delete: if false;
    }
    match /messages/{id} {
      allow read: if isAuthenticated() && (
        resource.data.recipientId == request.auth.uid
        || resource.data.senderId == request.auth.uid
        || isHQ()
      );
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.recipientId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'isRead',
                      'readAt',
                      'updatedAt'
                    ]);
      allow delete: if isAuthenticated() && (
        resource.data.recipientId == request.auth.uid
        || resource.data.senderId == request.auth.uid
        || isHQ()
      );
    }

    // Fulfillments: Server-managed, HQ read
    match /fulfillments/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isHQ());
      allow write: if false; // Server-only
    }

    // Rubrics
    match /rubrics/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isEducator();
      allow delete: if false;
    }
    match /rubricApplications/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create, update: if isEducator();
      allow delete: if false;
    }

    // Marketplace
    match /marketplaceListings/{id} {
      allow read: if isAuthenticated();
      allow create: if isHQ() || (isAuthenticated() && request.resource.data.partnerId == request.auth.uid);
      allow update: if isHQ() || (
        isAuthenticated()
        && resource.data.partnerId == request.auth.uid
        && request.resource.data.partnerId == resource.data.partnerId
      );
      allow delete: if false;
    }

    // --- Safeguarding Collections (HIGH priority) ---

    // Media Consents
    match /mediaConsents/{id} {
      allow read: if isAuthenticated() && (resource.data.parentId == request.auth.uid || resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && (request.resource.data.parentId == request.auth.uid || isEducator());
      allow update: if isAuthenticated() && (resource.data.parentId == request.auth.uid || isHQ());
      allow delete: if false;
    }

    // Pickup Authorizations
    match /pickupAuthorizations/{id} {
      allow read: if isAuthenticated() && (resource.data.parentId == request.auth.uid || isEducator());
      allow create: if isAuthenticated() && (request.resource.data.parentId == request.auth.uid || isEducator());
      allow update: if isAuthenticated() && (resource.data.parentId == request.auth.uid || isHQ());
      allow delete: if false;
    }

    // Incident Reports
    match /incidentReports/{id} {
      allow read: if isEducator() || isHQ();
      allow create: if isEducator();
      allow update: if isHQ();
      allow delete: if false;
    }

    // Site Check In/Out
    match /siteCheckInOut/{id} {
      allow read: if isAuthenticated() && (resource.data.learnerId == request.auth.uid || isEducator());
      allow create: if isEducator();
      allow update: if isEducator();
      allow delete: if false;
    }

    // --- Partner & Contracting ---

    match /partnerOrgs/{id} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isHQ());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isHQ());
      allow delete: if false;
    }
    match /partnerContracts/{id} {
      allow read: if isAuthenticated() && (resource.data.partnerId == request.auth.uid || isHQ());
      allow create: if isHQ() || (isAuthenticated() && request.resource.data.partnerId == request.auth.uid);
      allow update: if isHQ() || (
        isAuthenticated()
        && resource.data.partnerId == request.auth.uid
        && request.resource.data.partnerId == resource.data.partnerId
      );
      allow delete: if false;
    }
    match /partnerDeliverables/{id} {
      allow read: if isAuthenticated() && (resource.data.partnerId == request.auth.uid || isHQ());
      allow create: if isAuthenticated() && request.resource.data.partnerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.partnerId == request.auth.uid || isHQ());
      allow delete: if false;
    }
    match /payouts/{id} {
      allow read: if isAuthenticated() && (resource.data.partnerId == request.auth.uid || isHQ());
      allow create, update: if isHQ();
      allow delete: if false;
    }
    match /billingPlanChangeRequests/{id} {
      allow read: if isHQ() || (isAuthenticated() && hasSiteField(resource.data) && userHasSite(resource.data.siteId));
      allow write: if false; // Server-only via callable boundary.
    }

    // --- AI Drafts ---
    match /aiDrafts/{id} {
      allow read: if isAuthenticated() && ((resource.data.requesterId == request.auth.uid || resource.data.requestedBy == request.auth.uid) || isEducator());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && ((resource.data.requesterId == request.auth.uid || resource.data.requestedBy == request.auth.uid) || isEducator());
      allow delete: if false;
    }

    // --- Integration Collections (HQ/Server only) ---

    match /integrationConnections/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only
    }
    match /externalCourseLinks/{id} {
      allow read: if isEducator();
      allow write: if false; // Server-only
    }
    match /externalUserLinks/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only
    }
    match /externalCourseworkLinks/{id} {
      allow read: if isEducator();
      allow write: if false; // Server-only
    }
    match /syncJobs/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only
    }
    match /syncCursors/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only
    }
    match /githubConnections/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only — contains OAuth tokens
    }
    match /externalRepoLinks/{id} {
      allow read: if isEducator();
      allow write: if false; // Server-only
    }
    match /externalPullRequestLinks/{id} {
      allow read: if isEducator();
      allow write: if false; // Server-only
    }
    match /githubWebhookDeliveries/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only
    }
    match /externalIdentityLinks/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only — identity federation
    }

    // ── Additional collections discovered in Flutter services ──
    match /presenceRecords/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }
    match /missionAssignments/{id} {
      allow read: if isAuthenticated();
      allow create: if isEducator();
      allow update: if isEducator();
      allow delete: if false;
    }
    match /conversations/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }
    match /incidents/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isEducator();
      allow delete: if false;
    }
    match /skillAssessments/{id} {
      allow read: if isAuthenticated();
      allow create: if isEducator();
      allow update: if isEducator();
      allow delete: if false;
    }
    match /learnerProgress/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-only writes
    }
    match /activities/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-only writes
    }
    match /events/{id} {
      allow read: if isAuthenticated();
      allow create: if isEducator();
      allow update: if isEducator();
      allow delete: if false;
    }
    match /billingAccounts/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-only — billing is admin-managed
    }
    match /payments/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-only — payment records
    }
    match /habitLogs/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }
    match /offlineDemoActions/{id} {
      allow read, write: if isAuthenticated(); // Demo/test only
    }
    match /checkins/{id} {
      allow read: if isAuthenticated() && isSiteScopedRead(resource.data) &&
                  (isEducator() || resource.data.learnerId == request.auth.uid);
      allow create: if isEducator() && isSiteScopedWrite(request.resource.data);
      allow update: if isEducator() && isSiteScopedWrite(request.resource.data);
      allow delete: if false;
    }
    match /siteOpsEvents/{id} {
      allow read: if isAuthenticated() && isSiteScopedRead(resource.data);
      allow create, update: if isEducator() && isSiteScopedWrite(request.resource.data);
      allow delete: if false;
    }
    match /featureFlags/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningExperiments/{id} {
      allow read: if isHQ() || (
        hasRoleSafe('site')
        && resource.data.keys().hasAny(['allowedSiteIds'])
        && resource.data.allowedSiteIds.hasAny(actorSiteIds())
      );
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningUpdateSummaries/{id} {
      allow read: if isHQ() || (
        hasRoleSafe('site')
        && isSiteScopedRead(resource.data)
      );
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningAggregationRuns/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningMergeArtifacts/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningCandidateModelPackages/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /supportInterventions/{id} {
      allow read: if isEducator() && isSiteScopedRead(resource.data);
      allow write: if false; // Server-only via callable boundary.
    }
    match /drafts/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── BOS+MIA Runtime Collections ──────────────────

    // interactionEvents: client writes, server reads for FDM pipeline
    match /interactionEvents/{id} {
      allow read: if isHQ() || isAdminOrHQ();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // fdmFeatures: server-written feature windows, read by server only
    match /fdmFeatures/{id} {
      allow read: if isHQ() || isAdminOrHQ();
      allow create, update: if false;
      allow delete: if false;
    }

    // orchestrationStates: server writes x_hat + P, learner/educator reads own
    match /orchestrationStates/{id} {
      allow read: if isAuthenticated();
      allow create, update: if false;
      allow delete: if false;
    }

    // interventions: server writes, client reads own interventions
    match /interventions/{id} {
      allow read: if isAuthenticated();
      allow create, update: if false;
      allow delete: if false;
    }

    // mvlEpisodes: server creates gate, client can submit evidence
    match /mvlEpisodes/{id} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['evidenceEventIds']);
      allow delete: if false;
    }

    // fairnessAudits: server writes, HQ reads
    match /fairnessAudits/{id} {
      allow read: if isHQ() || isAdminOrHQ();
      allow create, update, delete: if false;
    }

    // classInsights: server writes, educator reads own site
    match /classInsights/{id} {
      allow read: if isAuthenticated() && (isEducator() || isHQ() || isAdminOrHQ());
      allow create, update, delete: if false;
    }

    match /rosterImports/{id} {
      allow read: if isAuthenticated() && (isEducator() || isHQ() || isAdminOrHQ());
      allow create, update: if (isEducator() || isHQ() || isAdminOrHQ())
                            && isSiteScopedWrite(request.resource.data);
      allow delete: if false;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
