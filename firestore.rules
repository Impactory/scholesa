      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningRuntimeDeliveryRecords/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /federatedLearningRuntimeActivationRecords/{id} {
      allow read: if isHQ();
      allow write: if false; // Server-only via callable boundary.
    }
    match /supportInterventions/{id} {
      allow read: if isEducator() && isSiteScopedRead(resource.data);
      allow write: if false; // Server-only via callable boundary.
    }
    match /drafts/{id} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ── BOS+MIA Runtime Collections ──────────────────

    // interactionEvents: client writes own events, server reads for FDM pipeline
    match /interactionEvents/{id} {
      allow read: if isHQ() || isAdminOrHQ() || (isEducator() && hasSiteField(resource.data) && isSiteScopedRead(resource.data));
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.actorId == request.auth.uid  // Backend uses actorId field
      );
      allow update: if false;
      allow delete: if false;
    }

    // fdmFeatures: server-written feature windows, read by server only
    match /fdmFeatures/{id} {
      allow read: if isHQ() || isAdminOrHQ();
      allow create, update: if false;
      allow delete: if false;
    }

    // orchestrationStates: server writes x_hat + P, learner/educator reads own
    match /orchestrationStates/{id} {
      allow read: if isAuthenticated();
      allow create, update: if false;
      allow delete: if false;
    }

