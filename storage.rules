rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    match /partnerDeliverables/{contractId}/{fileName} {
      allow read: if request.auth != null && (request.auth.token.role in ['partner', 'hq', 'site']);
      allow write: if request.auth != null && (request.auth.token.role in ['partner', 'hq']);
    }

    match /notificationUploads/{threadId}/{fileName} {
      allow read: if request.auth != null && request.auth.token.role in ['hq', 'site'];
      allow write: if request.auth != null && request.auth.token.role in ['hq', 'site'];
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
