rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated()
        && request.auth.token.role == role;
    }

    function isHQ() {
      return hasRole('hq');
    }

    function isSameSiteStaff() {
      return hasRole('educator') || hasRole('siteLead') || hasRole('site');
    }

    function actorSiteIds() {
      return request.auth.token.keys().hasAny(['siteIds'])
        ? request.auth.token.siteIds
        : [];
    }

    function isLinkedGuardian(learnerId) {
      return request.auth.token.keys().hasAny(['linkedLearnerIds'])
        && request.auth.token.linkedLearnerIds.hasAny([learnerId]);
    }

    function requestSharesActorSite() {
      return request.resource.metadata.keys().hasAny(['siteId'])
        && actorSiteIds().size() > 0
        && actorSiteIds().hasAny([request.resource.metadata.siteId]);
    }

    function resourceSharesActorSite() {
      return resource.metadata.keys().hasAny(['siteId'])
        && actorSiteIds().size() > 0
        && actorSiteIds().hasAny([resource.metadata.siteId]);
    }

    function canReadLearnerMedia(learnerId) {
      return isAuthenticated()
        && (
          request.auth.uid == learnerId
          || isLinkedGuardian(learnerId)
          || isHQ()
          || (isSameSiteStaff() && resourceSharesActorSite())
        );
    }

    function reportShareRequestPath(shareRequestId) {
      return /databases/(default)/documents/reportShareRequests/$(shareRequestId);
    }

    function reportShareRequest(shareRequestId) {
      return firestore.get(reportShareRequestPath(shareRequestId)).data;
    }

    function reportShareExists(shareRequestId) {
      return firestore.exists(reportShareRequestPath(shareRequestId));
    }

    function reportShareHasActorSite(shareRequestId) {
      return actorSiteIds().size() > 0
        && actorSiteIds().hasAny([reportShareRequest(shareRequestId).siteId]);
    }

    function isActiveReportShareForLearner(learnerId, shareRequestId) {
      return reportShareExists(shareRequestId)
        && reportShareRequest(shareRequestId).status == 'active'
        && reportShareRequest(shareRequestId).learnerId == learnerId
        && reportShareRequest(shareRequestId).expiresAt > request.time;
    }

    function canReadReportShareMedia(learnerId, shareRequestId) {
      return isAuthenticated()
        && isActiveReportShareForLearner(learnerId, shareRequestId)
        && (
          request.auth.uid == learnerId
          || request.auth.uid == reportShareRequest(shareRequestId).createdBy
          || isLinkedGuardian(learnerId)
          || isHQ()
          || (isSameSiteStaff() && reportShareHasActorSite(shareRequestId))
        );
    }

    // Partner deliverables: partner/HQ can upload (max 25MB), auth required for read
    match /partnerDeliverables/{contractId}/{fileName} {
      allow read: if request.auth != null && (request.auth.token.role in ['partner', 'hq', 'site']);
      allow write: if request.auth != null
                   && (request.auth.token.role in ['partner', 'hq'])
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType.matches('application/.*|image/.*|text/.*');
    }

    // Notification/messaging uploads (max 10MB) — educators, site admin, HQ
    match /notificationUploads/{threadId}/{fileName} {
      allow read: if request.auth != null && request.auth.token.role in ['educator', 'siteLead', 'hq', 'site'];
      allow write: if request.auth != null
                   && request.auth.token.role in ['educator', 'siteLead', 'hq', 'site']
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Portfolio media uploads (max 50MB, images/video/audio/pdf)
    match /portfolioMedia/{learnerId}/{fileName} {
      allow read: if canReadLearnerMedia(learnerId);
      allow write: if request.auth != null
                   && request.auth.uid == learnerId
                   && requestSharesActorSite()
                   && request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|video/.*|audio/.*|application/pdf');
    }

    // Report-share media is readable only while the server-owned share lifecycle is active.
    match /reportShareMedia/{learnerId}/{shareRequestId}/{fileName} {
      allow read: if canReadReportShareMedia(learnerId, shareRequestId);
      allow write: if false;
    }

    // Incident report attachments (max 10MB, educator/HQ only)
    match /incidentAttachments/{reportId}/{fileName} {
      allow read: if request.auth != null && request.auth.token.role in ['educator', 'siteLead', 'hq'];
      allow write: if request.auth != null
                   && request.auth.token.role in ['educator', 'siteLead', 'hq']
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
