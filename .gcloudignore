# Ignore files for gcloud builds submit
.git/
.github/
node_modules/
.next/
.dart_tool/
.idea/
*.iml

# Flutter SDK mirror (do not upload)
flutter/

# Firebase functions
functions/

# Test files
*.test.ts
*.test.js
*.spec.ts
test/

# Docs (not needed for build)
docs/

# Local env files
.env
.env.local

# Large unnecessary files
*.xd
*.code-workspace
*.zip
*.class
*.java
*.log

# Other unnecessary folders
dataconnect/

# Flutter generated artifacts (large, reproducible, not required for CI gates)
apps/empire_flutter/app/build/
apps/empire_flutter/app/.dart_tool/
apps/empire_flutter/app/android/.gradle/
apps/empire_flutter/app/ios/Pods/
apps/empire_flutter/app/macos/Pods/
apps/empire_flutter/app/windows/flutter/ephemeral/
apps/empire_flutter/app/linux/flutter/ephemeral/
