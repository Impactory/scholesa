FROM node:24-bookworm-slim

WORKDIR /app

COPY package*.json ./
RUN npm ci --no-audit --no-fund --no-update-notifier --loglevel=error

COPY . .

ENV PORT=8080
ENV COMPLIANCE_ALLOW_UNAUTH=0

EXPOSE 8080

RUN useradd --user-group --create-home --shell /bin/false appuser
USER appuser

CMD ["node", "services/scholesa-compliance/src/server.js"]
